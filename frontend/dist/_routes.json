{
  "routes": [
    { "src": "/api/*", "dest": "https://nugens-api.onrender.com/api/:splat" },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/gen-e/*", "dest": "/gen-e/index.html" },
    { "src": "/hyperx/*", "dest": "/hyperx/index.html" },
    { "src": "/digihub/*", "dest": "/digihub/index.html" },
    { "src": "/units/*", "dest": "/units/index.html" },
    { "src": "/", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}

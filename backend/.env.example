# NuGens Backend Environment Variables
# Copy this file to .env and fill in all values

# ── SERVER ──
NODE_ENV=production
PORT=5000

# ── DATABASE (Render PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host:5432/nugens_db

# ── AUTH ──
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── FRONTEND ──
FRONTEND_URL=https://nugens.com

# ── ANTHROPIC AI ──
ANTHROPIC_API_KEY=sk-ant-...

# ── CLOUDFLARE R2 (Video Storage for HyperX) ──
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=nugens-hyperx-videos
CF_R2_PUBLIC_DOMAIN=pub.nugens.com   # Custom domain for R2

# ── STRIPE (Payments) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── EMAIL (Resend or SendGrid) ──
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=no-reply@nugens.com
